<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 定义日志存储路径 -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>
    <property name="APP_NAME" value="${APP_NAME:-eify}"/>

    <!-- 引用 Spring Boot 的版本配置 -->
    <springProperty scope="context" name="APP_VERSION" source="app.version" defaultValue="1.0.0"/>

    <!-- 引用 Spring Boot 的日志级别配置 -->
    <springProperty scope="context" name="LOG_LEVEL_ROOT" source="logging.level.root" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_EIFY" source="logging.level.com.eify" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_MYBATIS" source="logging.level.org.mybatis" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_PLUS" source="logging.level.com.baomidou.mybatisplus" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_LEVEL_SPRING" source="logging.level.org.springframework" defaultValue="INFO"/>

    <!-- ======================== 控制台输出（开发环境） ======================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.eify.common.log.layout.StructuredLogLayout">
                <appVersion>${APP_VERSION}</appVersion>
            </layout>
        </encoder>
    </appender>

    <!-- ======================== 生产环境专用日志文件（prod/staging） ======================== -->
    <springProfile name="prod,staging">

    <appender name="FILE_JSON_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>10000</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="FILE_JSON"/>
    </appender>

    <!-- 同步文件输出（被 FILE_JSON_ASYNC 引用） -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.eify.common.log.layout.StructuredLogLayout">
                <appVersion>${APP_VERSION}</appVersion>
            </layout>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    </springProfile>

    <!-- ======================== 开发环境专用日志文件 ======================== -->
    <appender name="DEV_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-dev.log</file>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.eify.common.log.layout.StructuredLogLayout">
                <appVersion>${APP_VERSION}</appVersion>
            </layout>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-dev.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ======================== 错误日志单独输出 ======================== -->
    <appender name="ERROR_FILE_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>5000</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.eify.common.log.layout.StructuredLogLayout">
                <appVersion>${APP_VERSION}</appVersion>
            </layout>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ======================== 开发环境配置 ======================== -->
    <springProfile name="dev,default,test">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="DEV_FILE"/>
            <appender-ref ref="ERROR_FILE_ASYNC"/>
        </root>

        <logger name="com.eify" level="${LOG_LEVEL_EIFY}"/>
        <logger name="org.springframework" level="${LOG_LEVEL_SPRING}"/>
        <logger name="org.mybatis" level="${LOG_LEVEL_MYBATIS}"/>
        <logger name="com.baomidou.mybatisplus" level="${LOG_LEVEL_PLUS}"/>
        <logger name="brave.Tracer" level="WARN"/>
        <logger name="brave" level="WARN"/>
    </springProfile>

    <!-- ======================== 生产环境配置（优化版） ======================== -->
    <springProfile name="prod">
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE_JSON_ASYNC"/>
            <appender-ref ref="ERROR_FILE_ASYNC"/>
        </root>

        <logger name="com.eify" level="${LOG_LEVEL_EIFY}"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.mybatis" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
        <logger name="brave.Tracer" level="WARN"/>
        <logger name="brave" level="WARN"/>
    </springProfile>

</configuration>
