# ============================================================
# Eify 环境变量模板
# ============================================================
# 使用方式:
#   cp .env.example .env
#   编辑 .env，替换所有占位符为真实值
#
# ⚠️ 安全须知:
#   - .env 已通过 .gitignore 排除，不会被提交到 Git
#   - .env.example (本文件) 不含真实密钥，可以安全提交
#   - 每个服务使用独立的强密码，禁止复用
#   - 生成命令: openssl rand -base64 32
# ============================================================

# ========== JWT 认证（生产环境必须设置） ==========
# 至少 256 位 (32 字节) 随机字符串，HMAC-SHA256 最低要求
# 生成: openssl rand -base64 32
# 开发环境使用 application-dev.yml 中的默认值，无需设置
JWT_SECRET=

# ========== 加密密钥（生产环境必须设置） ==========
# KEK (Key Encryption Key)，用于加密数据库中存储的 API Key
# 必须是 32 字节 Base64 编码值 (AES-256-GCM)
# 生成: openssl rand -base64 32
# 开发环境使用 application-dev.yml 中的默认值，无需设置
CRYPTO_KEK=

# ========== PostgreSQL 17（主数据库，承载业务表 + 向量表） ==========
PG_URL=jdbc:postgresql://localhost:5432/eify?stringtype=unspecified
PG_USERNAME=postgres
PG_PASSWORD=change_me_postgres_password

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
# Docker Compose 部署时 Redis 默认无密码（容器网络隔离），无需设置此项
# 如需 Redis 密码认证，需同步修改 docker-compose.yml 中 Redis 的 command（添加 --requirepass）
# REDIS_PASSWORD=change_me_redis_password
# REDIS_DATABASE=0

# ========== ClickHouse ==========
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me_clickhouse_password
# Vector HTTP 端点（含协议和端口）
# CLICKHOUSE_ENDPOINT=http://localhost:8123

# ========== Grafana（日志栈可视化） ==========
GRAFANA_PASSWORD=change_me_grafana_password

# ========== Embedding API（DashScope / OpenAI 兼容） ==========
EMBEDDING_API_KEY=change_me_embedding_api_key

# ========== 日志 ==========
LOG_PATH=./logs
